{
  "author": "Manuel Peliz",
  "license": "Apache-2.0",
  "name": "@mpeliz/gtplweb",
  "version": "1.0.0",
  "description": "Web component framework built on top of GTPL with AOT compilation.",
  "keywords": [
    "gtpl",
    "framework",
    "web-components",
    "aot",
    "typescript"
  ],
  "homepage": "https://www.npmjs.com/package/@mpeliz/gtplweb",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/garag-lib/GTPLWeb.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "type": "module",
  "main": "./dist/gtplweb.cjs.js",
  "module": "./dist/gtplweb.esm.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "tools/aot-prebuild.js",
    "tools/app-build.js",
    "tools/init-app.js",
    "tools/init-project.sh",
    "README.md",
    "LICENSE",
    "NOTICE",
    "CITATION.cff"
  ],
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "import": "./dist/gtplweb.esm.js",
      "require": "./dist/gtplweb.cjs.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "clean": "rm -rf dist src-aot",
    "aot": "node tools/aot-prebuild.js",
    "test": "npm run build:structured && node --test tests/*.test.mjs",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run typecheck && npm run build:bundle",
    "build:bundle": "npm run clean && npm run aot && rollup -c pro.rollup.config.mjs",
    "build:structured": "npm run clean && npm run aot && rollup -c rollup.config.mjs"
  },
  "bin": {
    "gtpl-aot": "tools/aot-prebuild.js",
    "gtpl-app-build": "tools/app-build.js",
    "gtpl-init": "tools/init-app.js"
  },
  "dependencies": {
    "@mpeliz/gtpl": "github:garag-lib/GTPL",
    "esbuild": "^0.25.11",
    "glob": "^11.0.3",
    "jsdom": "^27.0.1",
    "sass": "^1.93.3",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^28.0.9",
    "@rollup/plugin-node-resolve": "^15.3.0",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^11.1.6",
    "@types/jsdom": "^27.0.0",
    "@types/node": "^24.9.1",
    "rollup": "^4.9.6",
    "rollup-plugin-copy": "^3.5.0",
    "rollup-plugin-dts": "^6.2.3",
    "typescript": "^5.9.3"
  }
}
